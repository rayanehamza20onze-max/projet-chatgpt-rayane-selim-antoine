:root {
    --primary: #10a37f;
    --primary-hover: #1a7f64;
    --bg-dark: #0f0f11;
    --card-bg: #1e1e20;
    --text-light: #e1e1e6;
    --accent: #5436da;
}

/* Scrollbar personnalisée */
::-webkit-scrollbar { width: 8px; }
::-webkit-scrollbar-track { background: #121214; }
::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }
::-webkit-scrollbar-thumb:hover { background: var(--primary); }

body {
    font-family: 'Inter', 'Segoe UI', Roboto, sans-serif;
    background-color: var(--bg-dark);
    color: var(--text-light);
    margin: 0;
    line-height: 1.6;
}

.main-header {
    background: linear-gradient(135deg, #000 0%, #1a1a1c 50%, var(--primary) 100%);
    text-align: center;
    padding: 4rem 1rem;
    clip-path: polygon(0 0, 100% 0, 100% 85%, 0 100%);
    box-shadow: 0 4px 30px rgba(0,0,0,0.5);
}

.header-logo { 
    width: 60px; 
    filter: drop-shadow(0 0 10px var(--primary));
    margin-bottom: 15px;
}

.container { max-width: 1200px; margin: auto; }

.cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 25px;
    margin: -50px auto 50px;
    padding: 0 25px;
}

.card {
    background: var(--card-bg);
    padding: 30px;
    border-radius: 18px;
    text-align: center;
    cursor: pointer;
    border: 1px solid #2d2d30;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
}

.card:hover { 
    transform: translateY(-10px); 
    border-color: var(--primary);
    background: #252528;
    box-shadow: 0 15px 30px rgba(16, 163, 127, 0.2);
}

.icon { font-size: 2.5rem; margin-bottom: 15px; display: block; }

/* Modales */
.modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0; top: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(8px);
    animation: fadeIn 0.3s ease;
}

.modal-content {
    background: #18181b;
    margin: 3% auto;
    padding: 40px;
    width: 90%;
    max-width: 800px;
    border-radius: 24px;
    border: 1px solid #333;
    max-height: 85vh;
    overflow-y: auto;
    position: relative;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
}

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

.close { 
    position: sticky;
    top: 0;
    float: right;
    font-size: 2.5rem;
    cursor: pointer;
    color: #666;
    transition: 0.3s;
}
.close:hover { color: #ff5f5f; transform: rotate(90deg); }

/* Quiz Styles */
#question { font-size: 1.2rem; margin-bottom: 20px; padding: 15px; background: #252528; border-radius: 10px; }

.quiz-btn { 
    display: block; 
    width: 100%; 
    padding: 15px; 
    margin: 12px 0; 
    background: #2d2d30; 
    color: white; 
    border: 2px solid transparent; 
    border-radius: 12px; 
    cursor: pointer; 
    font-size: 1rem;
    font-weight: 600;
    transition: 0.3s;
}

.quiz-btn:hover:not(:disabled) { 
    border-color: var(--primary);
    background: #36363a;
    transform: scale(1.02);
}

.quiz-btn:disabled { cursor: default; }

.final-score { font-size: 3rem; font-weight: bold; color: var(--primary); }
.result-box { text-align: center; padding: 20px; border-top: 1px solid #333; }

/* Vidéo et Image */
.modal-img { width: 100%; border-radius: 15px; border: 1px solid #333; }
.video-container { border: 1px solid #333; box-shadow: 0 10px 20px rgba(0,0,0,0.3); }

p { margin-bottom: 1.5rem; color: #ccc; font-size: 1.05rem; }
h2 { color: var(--primary); margin-bottom: 20px; }
